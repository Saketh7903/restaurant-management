{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": "18901814-6025-4382-83ca-6d158a01f7e6"
  },
  "newProjectRoot": "projects",
  "projects": {
    "my-angular1-app": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
           "assets": [
  "src/favicon.ico",
  "src/assets"
],
            "styles": [
              "src/styles.css",
              "src/assets/feane/css/bootstrap.css",
              "src/assets/feane/css/style.css",
              "src/assets/feane/css/responsive.css"
            ],
            "scripts": [
              "src/assets/feane/js/jquery-3.4.1.min.js",
              "src/assets/feane/js/bootstrap.js",
              "src/assets/feane/js/custom.js"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "my-angular1-app:build:production"
            },
            "development": {
              "buildTarget": "my-angular1-app:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}
